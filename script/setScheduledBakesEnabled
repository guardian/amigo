#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Enable/disable scheduled bakes for a given stage.

Usage:
  script/setScheduledBakesEnabled -p <STAGE> [-d|-e] [-r <REGION>]
  script/setScheduledBakesEnabled --help

Required:
  -s <STAGE>         Stage name (e.g. PROD, CODE)

Action (optional):
  -d                 Disable scheduled bakes
  -e                 Enable scheduled bakes
                     If neither -d nor -e is provided, only current state is printed.

Optional:
  -r <REGION>        AWS region (default: eu-west-1)
  -h, --help         Show this help
EOF
}

STAGE=""
REGION="eu-west-1"
AWS_PROFILE="deployTools"
ACTION=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    -s)
      if [[ $# -lt 2 ]]; then
        echo "Error: stage (-p) requires a value (CODE/PROD)." >&2
        usage
        exit 1
      fi
      STAGE="$2"
      shift 2
      ;;
    -r)
      if [[ $# -lt 2 ]]; then
        echo "Error: -r requires a value." >&2
        usage
        exit 1
      fi
      REGION="$2"
      shift 2
      ;;
    -d)
      if [[ -n "$ACTION" && "$ACTION" != "disable" ]]; then
        echo "Error: -d and -e are mutually exclusive." >&2
        usage
        exit 1
      fi
      ACTION="disable"
      shift
      ;;
    -e)
      if [[ -n "$ACTION" && "$ACTION" != "enable" ]]; then
        echo "Error: -d and -e are mutually exclusive." >&2
        usage
        exit 1
      fi
      ACTION="enable"
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Error: Unknown argument '$1'" >&2
      usage
      exit 1
      ;;
  esac
done

if [[ -z "$STAGE" ]]; then
  echo "Error: -p <STAGE> is required." >&2
  usage
  exit 1
fi

PARAM="/${STAGE}/deploy/amigo/amigo.scheduledBakes.enabled"

get_current_value() {
  aws ssm get-parameter \
    --profile "$AWS_PROFILE" \
    --region "$REGION" \
    --name "$PARAM" \
    --query 'Parameter.Value' \
    --output text
}

echo "Current value of $PARAM: "
CURRENT_VALUE="$(get_current_value)"
echo "$CURRENT_VALUE"

if [[ "$ACTION" == "disable" ]]; then
  echo "Disabling scheduled bakes for stage '$STAGE'..."
  aws ssm put-parameter \
    --profile "$AWS_PROFILE" \
    --region "$REGION" \
    --name "$PARAM" \
    --type String \
    --value "false" \
    --overwrite
elif [[ "$ACTION" == "enable" ]]; then
  echo "Enabling scheduled bakes for stage '$STAGE'..."
  aws ssm put-parameter \
    --profile "$AWS_PROFILE" \
    --region "$REGION" \
    --name "$PARAM" \
    --type String \
    --value "true" \
    --overwrite
else
  echo "No action provided (-d or -e). Printed current state only."
  exit 0
fi

echo "New value of $PARAM"
get_current_value